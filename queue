package collections;
import java.util.*;

public class queue {
	public static void main(String[] args) {
		 PriorityQueue<Integer> q = new PriorityQueue<Integer>();
		q.add(3);
		q.add(10);
		q.add(1);
		q.add(8);
		q.add(7);
		System.out.println("Head is" + q.peek());
		System.out.println("Removed" + q.remove());
		System.out.println("Head is" + q.peek());
		System.out.println("Size is" + q.size());
		
		
	}

}
