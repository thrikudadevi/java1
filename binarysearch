public class Main {

    public static int recursiveSearch(int[] arr, int target, int low, int high) {
        
        if (low > high) {
            return -1;
        }

        int mid = low + (high - low) / 2;

       
        if (arr[mid] == target) {
            return mid;
        }

        
        if (arr[mid] < target) {
            return recursiveSearch(arr, target, mid + 1, high);
        }

        return recursiveSearch(arr, target, low, mid - 1);
    }

    public static void main(String[] args) {
        int[] sortedArray = {2, 5, 8, 12, 16, 23, 38, 56, 72};
        int target = 16;

        int result = recursiveSearch(sortedArray, target, 0, sortedArray.length - 1);

        if (result != -1) {
            System.out.println("Element found at index: " + result);
        } else {
            System.out.println("Element not found.");
        }
    }
}
